using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;

namespace AssetManagementSystem
{
    // 1. Create the Asset Class
    public class Asset
    {
        public int AssetID { get; set; }
        public string AssetName { get; set; }
        public string Department { get; set; }
        public double Value { get; set; }

        // Constructor to initialize attributes
        public Asset(int id, string name, string dept, double val)
        {
            AssetID = id;
            AssetName = name;
            Department = dept;
            Value = val;
        }

        // Method to display asset details
        public void DisplayInfo()
        {
            Console.WriteLine($"ID: {AssetID,-5} | Name: {AssetName,-15} | Dept: {Department,-10} | Value: {Value:C}");
        }
    }

    class Program
    {
        static void Main(string[] args)
        {
            string filePath = "assets.txt";

            // 2. Create at least five Asset objects and store them in a List
            List<Asset> assets = new List<Asset>
            {
                new Asset(101, "Server Rack", "IT", 120000),
                new Asset(102, "Office Desk", "HR", 15000),
                new Asset(103, "Laptop Pro", "IT", 75000),
                new Asset(104, "Conference TV", "Marketing", 55000),
                new Asset(105, "Ergonomic Chair", "HR", 8000)
            };

            // 3. Use File Processing to save records to a text file
            try
            {
                using (StreamWriter writer = new StreamWriter(filePath))
                {
                    foreach (var asset in assets)
                    {
                        // Storing as Comma Separated Values (CSV) for easy reading later
                        writer.WriteLine($"{asset.AssetID},{asset.AssetName},{asset.Department},{asset.Value}");
                    }
                }
                Console.WriteLine("Data successfully saved to assets.txt.\n");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error saving file: {ex.Message}");
            }

            // 4. Read the contents of the file and display the records
            Console.WriteLine("--- All Assets from File ---");
            if (File.Exists(filePath))
            {
                string[] lines = File.ReadAllLines(filePath);
                foreach (string line in lines)
                {
                    Console.WriteLine(line);
                }
            }

            // 5. Use LINQ to filter assets with a value > 50,000
            // 6. Call DisplayInfo() for the filtered assets
            Console.WriteLine("\n--- High-Value Assets (Value > 50,000) ---");
            
            var highValueAssets = assets.Where(a => a.Value > 50000);

            foreach (var asset in highValueAssets)
            {
                asset.DisplayInfo();
            }

            Console.WriteLine("\nPress any key to exit...");
            Console.ReadKey();
        }
    }
}
